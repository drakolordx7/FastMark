# Public URL of this FastMark instance (no trailing slash). Used for cookies and docs.
# Leave blank or set to http://localhost:3000 for LAN/dev — do not hardcode a production domain.
APP_URL=http://localhost:3000

# auto | true | false — auto uses Secure cookies only when APP_URL is https
COOKIE_SECURE=auto

# Generate with: openssl rand -base64 32
ENCRYPTION_SECRET=change-me-to-a-long-random-string
AUTH_SECRET=change-me-to-another-long-random-string

DATABASE_URL=postgres://fastmark:fastmark@postgres:5432/fastmark
REDIS_URL=redis://redis:6379

# Optional bootstrap only — prefer configuring AI in Settings UI
# OPENAI_BASE_URL=https://example.com/v1
# OPENAI_API_KEY=
# OPENAI_MODEL=
